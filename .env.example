# Server Configuration
PORT=3001
SERVER_URL=http://localhost:3001

# Database Configuration
DATABASE_URL=postgresql://promptuser:promptpass@localhost:5432/prompt_manager
SESSION_DATABASE_URL=redis://localhost:6379/0
RATE_LIMIT_DATABASE_URL=redis://localhost:6379/1
NOTIFICATION_DATABASE_URL=redis://localhost:6379/2

# Auth Secrets (all required)
# Minimum 32 characters, random string
SESSION_SECRET=
# Exactly 32 characters
ENCRYPTION_SALT=
# Minimum 32 characters, random string
TOKEN_SECRET=
# Exactly 32 characters
API_KEY_SECRET=

# Integration API Key Header
API_KEY_HEADER=PROMPT

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=10

# LLM Configuration
LM_STUDIO_URL=http://localhost:11434/v1
LLM_ALLOWED_TARGETS=lm-studio,vertex,openai,anthropic,grok

# Vertex AI
VERTEX_PROJECT_ID=your-project-id
VERTEX_LOCATION=us-central1
VERTEX_MODEL=gemini-3-flash-preview
VERTEX_SERVICE_ACCOUNT_JSON=./server/auth/vertex-service-account.json

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-nano

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5

# Grok (xAI)
GROK_API_KEY=
GROK_MODEL=grok-3-mini

# Email Notifications (optional)
RESEND_API_KEY=
ADMIN_EMAILS=

# Cloudflare Turnstile (optional, bot protection)
CF_TURNSTILE_SITE_KEY=
CF_TURNSTILE_SECRET_KEY=
