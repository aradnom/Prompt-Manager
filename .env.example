# Server Configuration
PORT=3001
DEV_SETTINGS=false

# Database Configuration
DATABASE_URL=postgresql://promptuser:promptpass@localhost:5432/prompt_manager
SESSION_DATABASE_URL=redis://localhost:6379/0

# Auth-related Configuration
SESSION_SECRET=change-this-to-a-random-secret-in-production
ENCRYPTION_SALT=change-this-to-a-random-32-char-string
TOKEN_SECRET=change-this-to-a-random-secret-for-token-hashing

# External API Configuration
API_KEY_SECRET=32-char-string
API_KEY_HEADER=PROMPT

# LLM Configuration
LM_STUDIO_URL=http://localhost:1234/v1
LLM_ALLOWED_TARGETS=lm-studio,vertex

# Vertex AI Configuration
VERTEX_PROJECT_ID=your-project-id
VERTEX_LOCATION=us-central1
VERTEX_MODEL=gemini-3-flash-preview
VERTEX_SERVICE_ACCOUNT_JSON=./server/auth/vertex-service-account.json
