{
  "name": "prompt-manager",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "tslint": "tsc --noEmit && tsc --noEmit --project server/tsconfig.json",
    "preview": "vite preview",
    "server": "tsx watch --clear-screen=false server/src/index.ts .env",
    "server:build": "tsc -p server/tsconfig.json",
    "prepare": "husky",
    "test:llm": "vitest run --config server/vitest.config.ts",
    "migrate": "tsx server/src/migrate.ts",
    "migrate:down": "tsx server/src/migrate.ts down",
    "migrate:check": "tsx server/src/migrate-check.ts",
    "deploy": "deploy/deploy.sh"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.71.2",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-yaml": "^6.1.2",
    "@codemirror/legacy-modes": "^6.5.2",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fontsource/pitagon-sans-mono": "^5.2.5",
    "@fontsource/quicksand": "^5.2.10",
    "@google-cloud/vertexai": "^1.10.0",
    "@google/genai": "^1.35.0",
    "@huggingface/transformers": "^3.8.1",
    "@panva/hkdf": "^1.2.1",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-query": "^5.90.12",
    "@trpc/client": "^11.8.0",
    "@trpc/react-query": "^11.8.0",
    "@trpc/server": "^11.8.0",
    "@types/ws": "^8.18.1",
    "@uiw/codemirror-theme-vscode": "^4.25.4",
    "@uiw/react-codemirror": "^4.25.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "connect-redis": "^9.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "diff": "^8.0.3",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "google-auth-library": "^10.5.0",
    "idb": "^8.0.3",
    "js-yaml": "^4.1.1",
    "kysely": "^0.28.9",
    "lucide-react": "^0.562.0",
    "motion": "^12.23.26",
    "openai": "^6.16.0",
    "pg": "^8.16.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.11.0",
    "react-textarea-autosize": "^8.5.9",
    "resend": "^6.9.4",
    "superjson": "^2.2.6",
    "tailwind-merge": "^3.4.0",
    "tailwindcss-animate": "^1.0.7",
    "unique-names-generator": "^4.7.1",
    "ws": "^8.20.0",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/diff": "^7.0.2",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.18.2",
    "@types/js-yaml": "^4.0.9",
    "@types/pg": "^8.16.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.23",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.14.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "nodemon": "^3.1.11",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.1.18",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.18.2",
    "vite": "^6.0.5",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": "24"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,css,md}": "prettier --write"
  }
}
